# ServiceNow MCP Toolkit — Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env

# =============================================================================
# REQUIRED: ServiceNow Instance
# =============================================================================

# Your ServiceNow instance URL (no trailing slash)
SERVICENOW_INSTANCE_URL=https://yourcompany.service-now.com

# =============================================================================
# REQUIRED: Authentication (choose one method)
# =============================================================================

# Authentication method: basic | oauth
SERVICENOW_AUTH_METHOD=basic

# --- Basic Auth ---
# Use for development and personal use
SERVICENOW_BASIC_USERNAME=your_username
SERVICENOW_BASIC_PASSWORD=your_password
# (Aliases also accepted: SERVICENOW_USERNAME / SERVICENOW_PASSWORD)

# --- OAuth 2.0 ---
# Recommended for production. Create an OAuth app in:
# ServiceNow -> System OAuth -> Application Registry
# See docs/SERVICENOW_OAUTH_SETUP.md for full setup steps.
#
# SERVICENOW_AUTH_METHOD=oauth
# SERVICENOW_OAUTH_CLIENT_ID=your_client_id
# SERVICENOW_OAUTH_CLIENT_SECRET=your_client_secret
# SERVICENOW_OAUTH_USERNAME=service_account_user
# SERVICENOW_OAUTH_PASSWORD=service_account_password
# (Aliases also accepted: SERVICENOW_CLIENT_ID / SERVICENOW_CLIENT_SECRET)

# =============================================================================
# PERMISSION TIERS (all default to false — safe-by-default)
# =============================================================================

# Tier 1: Enable create/update/delete for ITSM, catalog, users, agile
WRITE_ENABLED=false

# Tier 2: Enable CMDB CI write operations (requires WRITE_ENABLED=true)
CMDB_WRITE_ENABLED=false

# Tier 3: Enable scripting management — business rules, script includes (requires WRITE_ENABLED=true)
SCRIPTING_ENABLED=false

# Tier AI: Enable Now Assist / Generative AI tools (latest release)
# Requires Now Assist license on your ServiceNow instance
NOW_ASSIST_ENABLED=false

# ATF: Enable Automated Test Framework execution tools
ATF_ENABLED=false

# Fluent: Enable Fluent / now-sdk (ServiceNow SDK) tools
FLUENT_ENABLED=false

# =============================================================================
# TOOL PACKAGING (optional)
# =============================================================================

# Load a role-specific subset of tools instead of all 394
# Options: full | service_desk | change_coordinator | knowledge_author |
#          catalog_builder | system_administrator | platform_developer |
#          portal_developer | integration_engineer | itom_engineer |
#          agile_manager | ai_developer | devops_engineer | itam_analyst
MCP_TOOL_PACKAGE=full

# =============================================================================
# TRANSPORT (optional — default is stdio)
# =============================================================================

# How MCP clients connect: stdio (default) | sse | http
# stdio is used by Claude Desktop, Cursor, VS Code, etc. Use sse/http to expose
# the server (plus its REST API and web dashboard) over the network.
TRANSPORT=stdio

# HTTP/SSE bind settings (only used when TRANSPORT=sse or http)
PORT=3000
HOST=0.0.0.0

# Bearer token required on every HTTP/SSE request (Authorization: Bearer <key>).
# SECURITY: if you enable http/sse and leave this unset, the server is UNAUTHENTICATED.
# Always set SNMCP_API_KEY (and a specific CORS_ORIGIN) before exposing it on a network.
# SNMCP_API_KEY=change_me

# Allowed CORS origin for the HTTP API (default: * — tighten this in production)
# CORS_ORIGIN=*

# =============================================================================
# MULTI-INSTANCE (optional)
# =============================================================================

# Option A — a JSON config file listing all instances:
# SN_INSTANCES_CONFIG=./instances.json

# Option B — define instances via env vars. Replace <NAME> with an upper-case label
# (e.g. DEV, PROD). SN_DEFAULT_INSTANCE picks the one used when no instance is named.
# SN_DEFAULT_INSTANCE=DEV
# SN_INSTANCE_DEV_URL=https://dev.service-now.com
# SN_INSTANCE_DEV_AUTH=basic
# SN_INSTANCE_DEV_USERNAME=your_username
# SN_INSTANCE_DEV_PASSWORD=your_password
# SN_INSTANCE_DEV_CLIENT_ID=your_oauth_client_id           # when _AUTH=oauth
# SN_INSTANCE_DEV_CLIENT_SECRET=your_oauth_client_secret   # when _AUTH=oauth

# =============================================================================
# ADVANCED OPTIONS (optional)
# =============================================================================

# Default max records returned per query when a tool doesn't specify a limit (cap: 1000)
MAX_RECORDS=100

# Agile table prefix (default: rm_ for SAFe/Scrum modules)
AGILE_TABLE_PREFIX=rm_

# Logging verbosity: error | warn | info | debug
LOG_LEVEL=info

# Scrub passwords/tokens/secrets from logged data
REDACT_SENSITIVE_DATA=true

# HTTP client tuning (milliseconds, except MAX_RETRIES)
MAX_RETRIES=3
RETRY_DELAY_MS=1000
REQUEST_TIMEOUT_MS=30000
