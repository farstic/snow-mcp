{
  "name": "servicenow-mcp",
  "mcpName": "io.github.cvetomirgrigorov/servicenow-mcp",
  "version": "1.0.0",
  "description": "ServiceNow MCP server exposing 394 tools across ITSM, CMDB, scripting, platform, and AI domains over stdio/SSE/HTTP, with role-based tool packages and dynamic schema discovery.",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./client": {
      "types": "./dist/servicenow/client.d.ts",
      "import": "./dist/servicenow/client.js"
    },
    "./reports": {
      "types": "./dist/reports/index.d.ts",
      "import": "./dist/reports/index.js"
    }
  },
  "bin": {
    "servicenow-mcp": "dist/cli/index.js"
  },
  "type": "module",
  "files": [
    "dist/",
    "desktop/serve.cjs",
    "desktop/renderer/dist/",
    "instances.example.json",
    ".env.example"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && node scripts/extract-tools.mjs",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "setup": "node dist/cli/index.js setup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "servicenow",
    "servicenow-mcp",
    "servicenow-mcp-server",
    "servicenow-ai",
    "servicenow-agent",
    "servicenow-automation",
    "servicenow-developer-tools",
    "servicenow-integration",
    "servicenow-api",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "itsm",
    "itom",
    "hrsd",
    "csm",
    "secops",
    "grc",
    "cmdb",
    "now-assist",
    "atf",
    "flow-designer",
    "service-portal",
    "performance-analytics",
    "service-catalog",
    "app-studio",
    "scoped-app",
    "ai-agent",
    "agentic",
    "typescript",
    "automation",
    "byok",
    "sdk",
    "servicenow-sdk"
  ],
  "author": "Cvetomir Grigorov",
  "homepage": "https://github.com/cvetomirgrigorov/servicenow-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cvetomirgrigorov/servicenow-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/cvetomirgrigorov/servicenow-mcp/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "overrides": {
    "minimatch": "^10.2.2"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^16.4.5",
    "ora": "^9.3.0",
    "pdfmake": "^0.3.7",
    "pptxgenjs": "^4.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
